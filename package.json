{
  "name": "herzog",
  "version": "0.1.0",
  "private": true,
  "description": "HERZOG AI film director and multi-agent studio system.",
  "type": "module",
  "engines": {
    "node": "20.20.0",
    "npm": "11.8.0"
  },
  "scripts": {
    "list:agents": "find .agents/agents -maxdepth 5 -type f ! -name .DS_Store | sort",
